# ================================================
# Insurance Data Pipeline - Environment Variables
# ================================================
# Copy this file to .env and fill in your values
# Command: cp .env.example .env
# NEVER commit .env to GitHub - it contains real secrets
# ================================================

# ---- MinIO Configuration (AWS S3 Equivalent) ----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET_RAW=insurance-raw
MINIO_BUCKET_PROCESSED=insurance-processed

# ---- DuckDB Configuration (Redshift Equivalent) ----
DUCKDB_DATABASE_PATH=./data/warehouse/insurance.duckdb

# ---- Airflow Configuration (Step Functions Equivalent) ----
AIRFLOW_UID=50000
AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=admin123
AIRFLOW_FERNET_KEY=your-fernet-key-here

# ---- Pipeline Configuration ----
PIPELINE_ENV=local
PIPELINE_LOG_LEVEL=INFO
RAW_DATA_URL=https://raw.githubusercontent.com/stedy/Machine-Learning-with-R-datasets/master/insurance.csv

# ---- Data Quality Configuration ----
GE_DATA_DOCS_PATH=./docs/data_quality

# ---- CI/CD Configuration ----
PYTHONPATH=.

